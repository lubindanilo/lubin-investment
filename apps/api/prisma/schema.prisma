// Prisma schema — Lubin Investment
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // native       → macOS local dev (Darwin arm64/x64)
  // rhel-openssl-3.0.x → Vercel serverless runtime (Amazon Linux 2023, OpenSSL 3)
  // Sans ce target, Prisma plante au cold start : "Could not load engine"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Utilisateur — auth email/password locale (pas de social pour le moment).
/// Le passwordHash est un bcrypt cost 12. L'email est normalisé en lowercase à l'insert.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  watchlist WatchlistEntry[]
}

/// Analyse qualitative du BUSINESS MODEL — cache À VIE (immutable une fois généré).
///
/// Pourquoi immutable : le business model d'une boîte évolue à l'échelle des années
/// (refonte produit, pivot stratégique), pas des semaines. Et chaque génération coûte
/// un appel GPT-4o-search-preview (~$0.05-0.10). On freeze pour éviter de cramer la clé
/// API à chaque rechargement. Si vraiment il faut regénérer (rare cas), suppression
/// manuelle de la ligne DB.
///
/// verdictDirect = la 1-2 phrases punchy affichée en haut du ScoreCard. Vit avec
/// business car concerne le nature de la société.
model BusinessAnalysis {
  ticker        String   @id
  /// JSON contenant business: Criterion[] (10 critères)
  business      Json
  /// 1-2 phrases punchy
  verdictDirect String
  createdAt     DateTime @default(now())
}

/// Analyse qualitative du MANAGEMENT — RAFRAÎCHISSABLE manuellement.
///
/// Le management peut changer (départ CEO/CFO, scandale, board reshuffle) à des
/// échelles plus courtes que le business. L'utilisateur déclenche un refresh via
/// bouton dédié. Pas de TTL automatique — l'utilisateur sait quand il y a un changement.
model ManagementAnalysis {
  ticker     String   @id
  /// JSON contenant management: Criterion[] (5 critères)
  management Json
  updatedAt  DateTime @default(now()) @updatedAt
}

/// Cache GLOBAL par ticker du résultat de l'analyse quant.
///
/// Source unique de vérité partagée entre /api/analyze et /api/watchlist :
/// quand l'utilisateur clique sur "Analyser" pour un ticker, le résultat (score,
/// chiffres, métriques) est écrit ici. La watchlist lit DIRECTEMENT depuis cette
/// table — elle ne recompute jamais. Conséquence : impossible de diverger.
///
/// Global (pas per-user) car les fundamentaux sont universels.
model TickerQuantSnapshot {
  ticker      String   @id
  snapshot    Json
  refreshedAt DateTime @default(now())

  @@index([refreshedAt])
}

/// Veille quantitative automatique ("screener"). Une ligne par ticker de l'univers.
/// La note /10 (quanti uniquement, jamais de GPT) est recalculée quand `nextEarningsDate`
/// est atteinte — le quantitatif ne bouge qu'aux résultats. Tant que la date est future,
/// le score reste en cache. Le détail complet vit dans TickerQuantSnapshot.
///
/// Couverture progressive : priority 0=US, 1=EU, 2=OTHER (le worker pioche dans cet ordre).
model ScreenerTicker {
  ticker             String    @id
  exchange           String?
  name               String?
  currency           String?
  region             String    @default("US")
  priority           Int       @default(0)
  /// pending | scored | nodata | error
  status             String    @default("pending")
  scoreChiffres      Int?
  scoreChiffresMax   Int?
  /// scoreChiffres / scoreChiffresMax — indexé pour le tri "meilleures notes"
  scoreRatio         Float?
  pfcfTTM            Float?
  /// Métadonnées d'affichage du screener
  sector             String?
  price              Float?
  /// Variation du jour en %
  dayChangePct       Float?
  /// Closes mensuels ~1 an pour la sparkline (number[])
  spark              Json?
  fundamentalsSource String?
  /// Date du prochain earnings (YYYY-MM-DD) — pilote le re-scoring
  nextEarningsDate   String?
  lastScoredAt       DateTime?
  attempts           Int       @default(0)
  updatedAt          DateTime  @updatedAt

  @@index([status, priority, lastScoredAt])
  @@index([scoreRatio])
}

/// Watchlist par utilisateur. Un même ticker peut apparaître chez plusieurs users (différentes lignes).
/// Les champs `snapshot` + `refreshedAt` sont legacy — gardés pour backward-compat mais
/// plus utilisés depuis l'introduction de TickerQuantSnapshot (cache global).
model WatchlistEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  ticker    String
  addedAt   DateTime @default(now())
  /// Snapshot du dernier refresh (P/FCF, score chiffres, etc.) — nullable au premier ajout
  snapshot  Json?
  /// Date du dernier rafraîchissement
  refreshedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Un user ne peut pas avoir le même ticker deux fois
  @@unique([userId, ticker])
  @@index([userId])
}
