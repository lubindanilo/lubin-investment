// Prisma schema — Lubin Investment
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // native       → macOS local dev (Darwin arm64/x64)
  // rhel-openssl-3.0.x → Vercel serverless runtime (Amazon Linux 2023, OpenSSL 3)
  // Sans ce target, Prisma plante au cold start : "Could not load engine"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Utilisateur — auth email/password locale (pas de social pour le moment).
/// Le passwordHash est un bcrypt cost 12. L'email est normalisé en lowercase à l'insert.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  watchlist WatchlistEntry[]
}

/// Cache qualitatif par ticker — PARTAGÉ entre tous les utilisateurs.
/// L'analyse GPT d'un business ne dépend pas de l'utilisateur qui demande, donc on dédup'.
model QualitativeCache {
  ticker    String   @id
  /// JSON contenant { business: Criterion[], management: Criterion[], verdict_direct: string }
  data      Json
  updatedAt DateTime @default(now()) @updatedAt
}

/// Watchlist par utilisateur. Un même ticker peut apparaître chez plusieurs users (différentes lignes).
model WatchlistEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  ticker    String
  addedAt   DateTime @default(now())
  /// Snapshot du dernier refresh (P/FCF, score chiffres, etc.) — nullable au premier ajout
  snapshot  Json?
  /// Date du dernier rafraîchissement
  refreshedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Un user ne peut pas avoir le même ticker deux fois
  @@unique([userId, ticker])
  @@index([userId])
}
