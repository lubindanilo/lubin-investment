# ============================================================
# Lubin Investment — Variables d'environnement (template)
# Copie ce fichier en `.env` puis remplis les valeurs.
# Ne commit JAMAIS .env (déjà dans .gitignore).
# ============================================================

# --- Postgres (local Docker) -----------------------------------
# La string ci-dessous matche docker-compose.yml — ne change que si tu adaptes le compose.
DATABASE_URL="postgresql://lubin:lubin@localhost:5432/lubin_investment?schema=public"

# --- API externes (côté serveur uniquement) --------------------
# OpenAI : qualitatif + verdict
OPENAI_API_KEY="sk-proj-..."

# Modèle OpenAI :
#   - "gpt-4o-2024-11-20"     : cutoff fin 2024, plus rapide/moins cher, infos 2025-2026 inconnues
#   - "gpt-4o-search-preview" : recherche web temps réel, ~2× plus cher, infos CEO/news actuelles
#   - "gpt-4o-mini-search-preview" : équivalent moins cher pour recherche web
OPENAI_MODEL="gpt-4o-search-preview"

# Finnhub : free tier — https://finnhub.io
FINNHUB_API_KEY="..."

# Financial Modeling Prep : free tier limité (profile uniquement)
FMP_API_KEY="..."

# --- Backend ---------------------------------------------------
API_PORT=3001
NODE_ENV="development"

# --- Sentry (optionnel — laisse vide pour désactiver) ----------
# Backend
SENTRY_DSN=""
SENTRY_RELEASE=""

# --- Frontend (Vite expose les vars prefixées VITE_) -----------
# URL du backend depuis le browser
VITE_API_URL="http://localhost:3001"
# Sentry React (optionnel)
VITE_SENTRY_DSN=""
